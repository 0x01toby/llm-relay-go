# LLM Relay Service (Go) — environment variables.
# Copy to .env and fill in.

# --- Spike (Phase 0) ---
# The OpenAI-compatible upstream base URL to relay to.
UPSTREAM_BASE_URL=https://api.openai.com/v1

# The credential sent to the upstream (provider API key). Paired with
# UPSTREAM_AUTH_HEADER below.
UPSTREAM_AUTH_VALUE=sk-replace-me

# Header name carrying the upstream credential (default Authorization).
# For Anthropic-style upstreams use "x-api-key".
# UPSTREAM_AUTH_HEADER=Authorization

# Port the spike listens on.
PORT=3300

# --- Full gateway (Phase P1+, reserved) ---
# PostgreSQL connection string (used from P2 onward).
# DATABASE_URL=postgresql://lrs:lrs@localhost:5432/lrs?sslmode=disable

# Gateway + console admin credential.
# GATEWAY_API_KEY=replace-me
